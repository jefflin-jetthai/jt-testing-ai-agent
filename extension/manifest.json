{
  "manifest_version": 3,
  "name": "JT Testing AI Agent",
  "version": "1.0.7",
  "key": "",
  "description": "讀 Notion 測試案例 → AI Agent 接管當前分頁執行 → 產出 markdown + gif → 可固化成 pytest commit",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "storage",
    "debugger",
    "scripting",
    "nativeMessaging",
    "clipboardRead"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "JT Testing AI Agent",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
